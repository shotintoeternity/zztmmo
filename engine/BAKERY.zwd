board "Social Plaza"
  max-shots 255
  dark false
  reenter false
  time-limit 0
  exits north "Bakery Gate" south none west "Bench Corner" east "Fountain Court"
  message "The plaza smells of bread you cannot reach."

  start player at 30,22
  grid
