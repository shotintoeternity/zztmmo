  end

  legend
    # = Solid color 0x06
    . = Empty color 0x00
    o = Object color 0x1B
    B = Breakable color 0x07
    p = Passage color 0x1F
    @ = Player color 0x1F under Empty color 0x00
  end

  stats
    stat at 30,10 element Object p1 cp437:0x09
    oop
@lens
#end
:touch
"Half-buried in cellar dust, the polished
lens waits."
"You lift it free. It is cold and
impossibly clear."
#set haslens
#die
    end
    stat at 30,18 element Passage
  end
end
